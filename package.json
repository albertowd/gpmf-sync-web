{
  "dependencies": {
    "lucide-react": "^1",
    "react": "^19",
    "react-dom": "^19"
  },
  "description": "Browser-side GoPro MP4 timestamp extractor — pure-JS port of gpmf-sync",
  "devDependencies": {
    "@biomejs/biome": "^1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^6"
  },
  "license": "AGPL-3.0-or-later",
  "name": "gpmf-sync-web",
  "private": true,
  "scripts": {
    "build": "tsc -b && vite build",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "dev": "vite",
    "format": "biome format --write src",
    "lint": "biome check src",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "type": "module",
  "version": "1.0.0"
}
