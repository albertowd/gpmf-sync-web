{
  "name": "gpmf-sync-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-side GoPro MP4 timestamp extractor — pure-JS port of gpmf-sync",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "ci": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
